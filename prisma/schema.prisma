generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum ExerciseCategory {
  CHEST
  TRICEPS
  BICEPS
  BACK
  LEGS
  SHOULDERS
  ARMS
  FULL_BODY
}

enum ExerciseType {
  STRENGTH
  CARDIO
  MOBILITY
  FLEXIBILITY
}

enum WorkoutSessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  INCOMPLETE
  SKIPPED
}

enum GoalType {
  LOSE
  GAIN
  MAINTAIN
}

enum BadgeType {
  WORKOUT
  EXERCISE
  STREAK
}

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String?
  avatarUrl String?

  height    Int?
  weight    Float?
  gender    String?
  birthdate DateTime?

  createdAt DateTime @default(now()) @map("created_at")

  exercise    Exercise[]
  myExercise  MyExercise[]
  exerciseLog ExerciseLog[]
  workout     Workout[]
  sessions    WorkoutSession[]

  streak UserStreak?

  WeightGoal       WeightGoal[]
  WeightLog        WeightLog[]
  UserBadge        UserBadge[]
  UserStreakLog    UserStreakLog[]
  workoutSchedules WorkoutSchedule[]

  @@map("users")
}

model Exercise {
  id       String            @id @default(cuid())
  name     String
  category ExerciseCategory?
  type     ExerciseType?

  isCustom  Boolean  @default(false) @map("is_custom")
  createdAt DateTime @default(now()) @map("created_at")

  userId          String?           @map("user_id")
  user            User?             @relation(fields: [userId], references: [id])
  myExercise      MyExercise[]
  exerciseLog     ExerciseLog[]
  workoutExercise WorkoutExercise[]
  sessions        ExerciseSession[]

  @@unique([name, userId])
  @@map("exercises")
}

model MyExercise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String
  exerciseId String

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
  @@map("my_exercises")
}

model Workout {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  userId      String

  user      User              @relation(fields: [userId], references: [id])
  exercises WorkoutExercise[]
  schedules WorkoutSchedule[]
  sessions  WorkoutSession[]

  @@map("workouts")
}

model WorkoutExercise {
  id        String @id @default(cuid())
  workoutId String

  exerciseId    String
  defaultSets   Int?
  defaultReps   Int?
  defaultWeight Float?

  workout  Workout  @relation(fields: [workoutId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([workoutId, exerciseId])
  @@map("workout_exercises")
}

model WorkoutSchedule {
  id        String @id @default(cuid())
  dayOfWeek Int
  userId    String
  workoutId String

  user    User    @relation(fields: [userId], references: [id])
  workout Workout @relation(fields: [workoutId], references: [id])

  @@unique([userId, dayOfWeek])
  @@map("workout_schedule")
}

model WorkoutSession {
  id     String               @id @default(cuid())
  date   DateTime             @default(now())
  status WorkoutSessionStatus @default(PENDING)

  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  duration  Int?

  userId    String
  workoutId String

  user             User              @relation(fields: [userId], references: [id])
  workout          Workout           @relation(fields: [workoutId], references: [id])
  exerciseSessions ExerciseSession[]

  @@map("workout_sessions")
}

model ExerciseSession {
  id        String  @id @default(cuid())
  completed Boolean @default(false)

  plannedSets   Int?
  plannedReps   Int?
  plannedWeight Float?

  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  duration  Int?

  workoutSessionId String
  exerciseId       String

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id])
  exercise       Exercise       @relation(fields: [exerciseId], references: [id])
  logs           ExerciseLog[]

  @@unique([workoutSessionId, exerciseId])
  @@map("exercise_sessions")
}

model ExerciseLog {
  id          String   @id @default(cuid())
  sets        Int
  reps        Int
  weight      Float?
  volume      Float?
  description String?
  date        DateTime @default(now())

  exerciseSessionId String
  userId            String
  exerciseId        String

  exerciseSession ExerciseSession @relation(fields: [exerciseSessionId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  exercise        Exercise        @relation(fields: [exerciseId], references: [id])

  @@map("exercise_logs")
}

model UserStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  bestStreak    Int       @default(0)
  lastWorkout   DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("streaks")
}

model UserStreakLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("user_streak_logs")
}

model WeightGoal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name        String
  description String?

  goalType     GoalType
  startWeight  Float?
  targetWeight Float
  startDate    DateTime  @default(now())
  endDate      DateTime?
  achievedAt   DateTime?
  isActive     Boolean   @default(true)
  progress     Float     @default(0)

  logs WeightLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("weight_goals")
}

model WeightLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  goalId String?
  goal   WeightGoal? @relation(fields: [goalId], references: [id])

  date   DateTime @default(now())
  weight Float
  note   String?

  createdAt DateTime @default(now())

  @@map("weight_logs")
}

model Badge {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  type        BadgeType
  milestone   Int?
  createdAt   DateTime  @default(now())

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}
