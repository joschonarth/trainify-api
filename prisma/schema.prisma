generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum ExerciseCategory {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  FULL_BODY
}

enum ExerciseType {
  STRENGTH
  CARDIO
  MOBILITY
  FLEXIBILITY
}

model User {
  id          String        @id @default(uuid())
  name        String
  email       String        @unique
  password    String
  createdAt   DateTime      @default(now()) @map("created_at")
  exercise    Exercise[]
  myExercise  MyExercise[]
  exerciseLog ExerciseLog[]
  workout     Workout[]

  @@map("users")
}

model Exercise {
  id        String            @id @default(cuid())
  name      String
  category  ExerciseCategory?
  type      ExerciseType?
  sets      Int?
  reps      Int?
  weight    Float?
  isCustom  Boolean           @default(false) @map("is_custom")
  createdAt DateTime          @default(now()) @map("created_at")

  userId          String?           @map("user_id")
  user            User?             @relation(fields: [userId], references: [id])
  myExercise      MyExercise[]
  exerciseLog     ExerciseLog[]
  workoutExercise WorkoutExercise[]

  @@unique([name, userId])
  @@map("exercises")
}

model MyExercise {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId     String
  exerciseId String

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
  @@map("my_exercises")
}

model ExerciseLog {
  id          String   @id @default(cuid())
  sets        Int
  reps        Int
  weight      Float?
  date        DateTime @default(now())
  description String?

  userId     String
  exerciseId String
  workoutId  String?

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  workout  Workout? @relation(fields: [workoutId], references: [id])

  @@map("exercise_logs")
}

model Workout {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  userId      String

  user        User              @relation(fields: [userId], references: [id])
  exercises   WorkoutExercise[]
  schedules   WorkoutSchedule[]
  exerciseLog ExerciseLog[]

  @@map("workouts")
}

model WorkoutExercise {
  id            String @id @default(cuid())
  workoutId     String
  exerciseId    String
  defaultSets   Int?
  defaultReps   Int?
  defaultWeight Float?

  workout  Workout  @relation(fields: [workoutId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([workoutId, exerciseId])
  @@map("workout_exercises")
}

model WorkoutSchedule {
  id        String @id @default(cuid())
  workoutId String
  dayOfWeek Int

  workout Workout @relation(fields: [workoutId], references: [id])

  @@unique([workoutId, dayOfWeek])
  @@map("workout_schedule")
}
